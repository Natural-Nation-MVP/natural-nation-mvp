{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founder-os.local/schemas/observability.schema.json",
  "title": "Founder OS Observability Record",
  "type": "object",
  "required": ["record_id", "workspace_id", "record_type", "observed_at", "source", "classification", "audit_ref"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "record_type": {"enum": ["metric", "health_check", "slo", "anomaly", "incident", "execution_signal", "integration_signal"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "source": {
      "type": "object",
      "required": ["kind", "source_id"],
      "properties": {
        "kind": {"enum": ["workflow", "execution_run", "integration", "service", "manual"]},
        "source_id": {"type": "string"},
        "evidence_ref": {"type": "string"}
      },
      "additionalProperties": false
    },
    "classification": {"enum": ["public", "internal", "confidential", "restricted"]},
    "freshness_seconds": {"type": "integer", "minimum": 0},
    "quality": {
      "type": "object",
      "properties": {
        "status": {"enum": ["verified", "estimated", "partial", "stale", "unknown"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "health_state": {"enum": ["healthy", "degraded", "at_risk", "unavailable", "unknown"]},
    "severity": {"enum": ["info", "low", "medium", "high", "critical"]},
    "correlation_key": {"type": "string"},
    "deduplication_key": {"type": "string"},
    "founder_attention_required": {"type": "boolean"},
    "remediation_workflow_id": {"type": "string"},
    "audit_ref": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
